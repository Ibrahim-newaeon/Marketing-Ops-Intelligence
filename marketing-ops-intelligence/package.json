{
  "name": "marketing-ops-intelligence",
  "version": "0.1.0",
  "private": true,
  "description": "Phase-gated multi-agent marketing pipeline for Gulf markets (KSA, KW, QA, AE, JO).",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "tsx watch core/server/index.ts",
    "build": "tsc -p tsconfig.json && next build dashboards",
    "start": "node dist/core/server/index.js",
    "dashboards:dev": "next dev dashboards -p 3001",
    "dashboards:build": "next build dashboards",
    "dashboards:start": "next start dashboards -p 3001",
    "db:migrate": "tsx core/db/migrate.ts",
    "db:seed": "tsx core/db/seed.ts",
    "memory:seed": "tsx core/utils/memory_seed.ts",
    "memory:backfill": "tsx core/memory/backfill_embeddings.ts",
    "cost:report": "tsx core/utils/cost_report.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p dashboards/tsconfig.json --noEmit",
    "test:unit": "vitest run",
    "test:playwright": "playwright test",
    "test:k6": "k6 run tests/k6/concurrent_multi_market.js && k6 run tests/k6/memory_retrieval_latency.js && k6 run tests/k6/dashboard_aggregation_load.js",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "axios": "^1.7.7",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "gray-matter": "^4.0.3",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "next": "14.2.15",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.5",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.12.0",
    "eslint-config-next": "14.2.15",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
