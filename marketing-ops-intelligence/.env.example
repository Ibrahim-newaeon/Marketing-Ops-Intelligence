# ─────────────────────────────────────────────────────────────────────
# Marketing Ops Intelligence — environment template
# Copy to .env and fill. NEVER commit .env.
# ─────────────────────────────────────────────────────────────────────

# Node / server
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/marketing_ops
PGSSLMODE=disable

# Auth (JWT)
JWT_SECRET=replace-with-64-char-random
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ─── WhatsApp Cloud API (Meta Graph) ─────────────────────────────────
WA_GRAPH_VERSION=v21.0
WA_PHONE_NUMBER_ID=
WA_BUSINESS_ACCOUNT_ID=
WA_ACCESS_TOKEN=
WA_APP_SECRET=
WA_WEBHOOK_VERIFY_TOKEN=
WA_PRINCIPAL_PHONE_AR=
WA_PRINCIPAL_PHONE_EN=

# ─── Claude / Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_OPUS=claude-opus-4-7
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001

# ─── Ad platforms ────────────────────────────────────────────────────
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_PIXEL_ID=
META_CAPI_TOKEN=

GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_PIXEL_ID=

SNAP_ACCESS_TOKEN=
SNAP_AD_ACCOUNT_ID=
SNAP_PIXEL_ID=

TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
TIKTOK_PIXEL_ID=
TIKTOK_CAPI_TOKEN=

GA4_MEASUREMENT_ID=
GA4_API_SECRET=

# ─── Approval gate ───────────────────────────────────────────────────
APPROVAL_TIMEOUT_HOURS=48

# ─── Rate limits ─────────────────────────────────────────────────────
API_RATE_LIMIT_PER_MIN=60
WA_RATE_LIMIT_PER_HOUR_PER_RECIPIENT=10
